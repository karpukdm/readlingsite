---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { links } from '../../config/links';
import allBooks from '../../data/books.json';
import { toSlug, complexityToLevel, genreLabels } from '../../utils/slug';

const books = allBooks
  .filter(b => !b.title.includes('Guide') && !b.title.includes('Руководство'));

// Group books by primary genre categories (order matters for display)
const genreOrder = [
  'CHILDRENS',
  'CLASSIC',
  'ADVENTURE',
  'MYSTERY',
  'SCIENCE_FICTION',
  'FANTASY',
  'HORROR',
  'ROMANCE',
  'DRAMA',
  'PHILOSOPHY',
  'BIOGRAPHY',
  'NON_FICTION',
  'SELF_HELP',
  'HISTORICAL',
  'POETRY',
];

// Assign each book to one primary genre (first matching from genreOrder)
const genreGroups = new Map<string, typeof books>();
const assigned = new Set<string>();

for (const genre of genreOrder) {
  const genreBooks = books.filter(b => {
    if (assigned.has(b.title)) return false;
    return b.genres.split(',').map((g: string) => g.trim()).includes(genre);
  });
  if (genreBooks.length > 0) {
    genreGroups.set(genre, genreBooks);
    genreBooks.forEach(b => assigned.add(b.title));
  }
}
---

<BaseLayout
  title="Книги на английском с переводом — каталог Readling"
  description="Более 200 книг на английском с русским переводом. Классика, детективы, фантастика, романтика — от уровня A1 до C2. Читайте в приложении Readling бесплатно 7 дней."
  canonicalPath="/books"
>
  <section class="section">
    <div class="container">
      <h1 class="text-center mb-m">Книги на английском с переводом</h1>
      <p class="text-center max-w-prose mx-auto mb-xxl">
        Выбирайте книгу по уровню и жанру. Каждая книга доступна с русским переводом
        в режиме параллельного чтения или погружения.
      </p>

      {Array.from(genreGroups.entries()).map(([genre, genreBooks]) => (
        <div class="genre-section">
          <h2 class="genre-section__title">{genreLabels[genre] || genre}</h2>
          <div class="books-grid">
            {genreBooks.map(book => (
              <a href={`/books/${toSlug(book.title)}`} class="book-item">
                <img class="book-item__cover" src={book.imageUrl} alt={book.title} loading="lazy" />
                <div class="book-item__info">
                  <span class="book-item__level">{complexityToLevel[book.complexity]}</span>
                  <div class="book-item__title">{book.title}</div>
                  <div class="book-item__author">{book.author}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <div class="more-books">
        <div class="more-books__inner">
          <h3 class="mb-s">Ещё больше книг — в приложении</h3>
          <p>
            Здесь показана часть каталога. В приложении Readling — более 200 книг на английском
            с переводом в 25 жанрах. Новые книги добавляются каждую неделю.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Книги на английском с переводом — каталог Readling",
      "description": "Более 200 книг на английском с русским переводом для изучения языка.",
      "url": "https://app.readling.club/books",
    })} />
  </Fragment>
</BaseLayout>

<style>
  .genre-section {
    margin-bottom: var(--space-3xl);
  }

  .genre-section__title {
    margin-bottom: var(--space-l);
    padding-bottom: var(--space-s);
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }

  .books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-l);
  }

  .book-item {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .book-item:hover {
    transform: translateY(-4px);
    color: inherit;
  }

  .book-item__cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-card-border);
    background: var(--color-surface-alt);
    margin-bottom: var(--space-s);
  }

  .book-item__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .book-item__level {
    display: inline-block;
    width: fit-content;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-xs);
  }

  .book-item__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .book-item__author {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .more-books {
    margin-top: var(--space-xl);
    border-top: 1px solid var(--color-card-border);
    padding-top: var(--space-3xl);
  }

  .more-books__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  @media (max-width: 480px) {
    .books-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-m);
    }
  }
</style>
