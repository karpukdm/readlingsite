---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { links } from '../../config/links';
import allBooks from '../../data/books.json';
import { toSlug, complexityToLevel, genreLabels } from '../../utils/slug';

export function getStaticPaths() {
  return allBooks
    .filter(b => !b.title.includes('Guide') && !b.title.includes('Руководство'))
    .map(book => ({
      params: { slug: toSlug(book.title) },
      props: { book },
    }));
}

const { book } = Astro.props;
const level = complexityToLevel[book.complexity] || 'B1';
const genres = book.genres.split(',').map((g: string) => g.trim());
const genreNames = genres.map((g: string) => genreLabels[g] || g).join(', ');
const isParallel = book.mode === 'параллельный';
const modeLabel = isParallel ? 'Параллельное чтение' : 'Режим погружения';
const slug = toSlug(book.title);

const levelDescription = book.complexity === 1 ? 'начальный' : book.complexity <= 3 ? 'средний' : book.complexity <= 5 ? 'продвинутый' : 'профессиональный';

// Related books: same genre or same level, excluding current
const otherBooks = allBooks.filter(b => !b.title.includes('Guide') && !b.title.includes('Руководство') && b.title !== book.title);
const bookGenres = new Set(genres);
const sameGenre = otherBooks.filter(b => b.genres.split(',').some((g: string) => bookGenres.has(g.trim())));
const sameLevel = otherBooks.filter(b => b.complexity === book.complexity);
// Prioritize same genre + same level, then same genre, then same level
const scored = otherBooks.map(b => {
  let score = 0;
  if (b.genres.split(',').some((g: string) => bookGenres.has(g.trim()))) score += 2;
  if (b.complexity === book.complexity) score += 1;
  if (Math.abs(b.complexity - book.complexity) === 1) score += 0.5;
  return { book: b, score };
}).filter(s => s.score > 0).sort((a, b) => b.score - a.score);
const relatedBooks = scored.slice(0, 6).map(s => s.book);

const pageTitle = `${book.title} на английском с переводом — читать в Readling`;
const pageDescription = `Читайте «${book.title}» (${book.author}) на английском языке с русским переводом в приложении Readling. ${isParallel ? 'Параллельный перевод' : 'Режим погружения'}, уровень ${level}. Скачайте бесплатно.`;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/books/${slug}`}
  ogImage={book.imageUrl}
>
  <!-- BREADCRUMBS -->
  <nav class="breadcrumbs">
    <div class="container">
      <a href="/">Главная</a>
      <span class="breadcrumbs__sep">/</span>
      <a href="/books/">Книги</a>
      <span class="breadcrumbs__sep">/</span>
      <span>{book.title}</span>
    </div>
  </nav>

  <!-- BOOK HERO -->
  <section class="book-hero">
    <div class="container book-hero__inner">
      <div class="book-hero__cover">
        <img src={book.imageUrl} alt={`Обложка книги «${book.title}»`} width="280" height="420" />
      </div>
      <div class="book-hero__info">
        <h1 class="mb-s">{book.title} — на английском с переводом</h1>
        <p class="book-hero__author mb-m">{book.author}</p>
        <div class="book-hero__tags mb-l">
          <span class="tag tag--level">{level}</span>
          <span class="tag tag--mode">{modeLabel}</span>
          {genres.map((g: string) => (
            <span class="tag">{genreLabels[g] || g}</span>
          ))}
        </div>
        <p class="book-hero__desc mb-l">{book.description}</p>
        <div class="store-buttons">
          <a href={links.appStore} target="_blank" rel="noopener" class="store-btn"><img src="/badge-appstore.svg" alt="Загрузите в App Store" /></a>
          <a href={links.googlePlay} target="_blank" rel="noopener" class="store-btn store-btn--google"><img src="/badge-google-play.png" alt="Доступно в Google Play" /></a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW TO READ -->
  <section class="section">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Как читать «{book.title}» на английском в Readling</h2>
      <div class="grid-3">
        <div class="card text-center">
          <h3 class="mb-s">1. Скачайте приложение</h3>
          <p>Readling доступен бесплатно в App Store и Google Play. Первые 7 дней — без ограничений.</p>
        </div>
        <div class="card text-center">
          <h3 class="mb-s">2. Найдите книгу в каталоге</h3>
          <p>Откройте каталог, найдите «{book.title}» и начните читать на английском с переводом.</p>
        </div>
        <div class="card text-center">
          <h3 class="mb-s">3. Читайте и учите слова</h3>
          <p>Нажимайте на незнакомые слова — они сохранятся в словарь. Закрепляйте тренировками.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MODE EXPLANATION -->
  {isParallel ? (
    <section class="section section--alt">
      <div class="container max-w-wide mx-auto">
        <h2 class="text-center mb-m">«{book.title}» с параллельным переводом</h2>
        <p class="text-center max-w-prose mx-auto mb-xxl">
          Эта книга доступна в режиме параллельного чтения. Вы видите английский оригинал
          и русский перевод рядом — предложение за предложением. Удобно сравнивать конструкции
          и понимать каждое слово.
        </p>
        <div class="mode-features grid-2">
          <div class="card">
            <h3 class="mb-s">Оригинал и перевод рядом</h3>
            <p>Английский текст и русский перевод идут параллельно. Если что-то непонятно — взгляните на перевод.</p>
          </div>
          <div class="card">
            <h3 class="mb-s">Перевод слов по нажатию</h3>
            <p>Нажмите на любое слово — увидите перевод, транскрипцию и примеры. Слово сохранится в ваш словарь.</p>
          </div>
        </div>
        <div class="text-center" style="margin-top: var(--space-xl);">
          <a href="/parallelnoe-chtenie/" class="btn btn--secondary">Подробнее о параллельном чтении &rarr;</a>
        </div>
      </div>
    </section>
  ) : (
    <section class="section section--alt">
      <div class="container max-w-wide mx-auto">
        <h2 class="text-center mb-m">«{book.title}» в режиме погружения</h2>
        <p class="text-center max-w-prose mx-auto mb-xxl">
          Эта книга доступна в режиме погружения. Вы начинаете читать почти на русском,
          а английские слова и фразы появляются постепенно. К концу книги вы читаете преимущественно на английском.
        </p>
        <div class="mode-features grid-2">
          <div class="card">
            <h3 class="mb-s">Плавный переход на английский</h3>
            <p>В начале книги — 10% английского текста. К середине — 50%. К концу — 90%. Мозг привыкает к языку естественно.</p>
          </div>
          <div class="card">
            <h3 class="mb-s">Перевод слов по нажатию</h3>
            <p>Нажмите на любое слово — увидите перевод, транскрипцию и примеры. Слово сохранится в ваш словарь.</p>
          </div>
        </div>
        <div class="text-center" style="margin-top: var(--space-xl);">
          <a href="/metod-pogruzheniya/" class="btn btn--secondary">Подробнее о методе погружения &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- ABOUT BOOK -->
  <section class="section">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">О книге «{book.title}»</h2>
      <div class="book-details">
        <div class="book-detail">
          <div class="book-detail__label">Автор</div>
          <div class="book-detail__value">{book.author}</div>
        </div>
        <div class="book-detail">
          <div class="book-detail__label">Уровень английского</div>
          <div class="book-detail__value">{level} ({levelDescription})</div>
        </div>
        <div class="book-detail">
          <div class="book-detail__label">Жанр</div>
          <div class="book-detail__value">{genreNames}</div>
        </div>
        <div class="book-detail">
          <div class="book-detail__label">Режим чтения</div>
          <div class="book-detail__value">{modeLabel}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY READ IN ENGLISH -->
  <section class="section section--alt">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Зачем читать «{book.title}» на английском</h2>
      <div class="grid-3">
        <div class="card">
          <h3 class="mb-s">Словарный запас из {genreNames.toLowerCase()}</h3>
          <p>«{book.title}» ({book.author}) — это {book.complexity <= 2 ? 'простая лексика, идеальная для начинающих' : book.complexity <= 4 ? 'богатая лексика среднего уровня' : 'продвинутая лексика для опытных читателей'}. Слова запоминаются в контексте живой истории, а не из учебника.</p>
        </div>
        <div class="card">
          <h3 class="mb-s">{isParallel ? 'Грамматика через сравнение языков' : 'Грамматика через погружение'}</h3>
          <p>{isParallel ? 'В параллельном режиме вы видите английскую и русскую версию рядом — идеально для анализа грамматических конструкций и порядка слов.' : 'В режиме погружения грамматика усваивается естественно — вы привыкаете к конструкциям, встречая их десятки раз в тексте.'}</p>
        </div>
        <div class="card">
          <h3 class="mb-s">Уровень {level} — {levelDescription}</h3>
          <p>{book.complexity <= 2 ? 'Книга подходит для тех, кто только начинает читать на английском. Простые предложения и частотная лексика.' : book.complexity <= 4 ? 'Книга подходит для читателей со средним уровнем. Разнообразные конструкции и расширенный словарный запас.' : 'Книга для продвинутых читателей. Сложные конструкции, редкая лексика, авторский стиль.'}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED BOOKS -->
  {relatedBooks.length > 0 && (
    <section class="section">
      <div class="container max-w-wide mx-auto">
        <h2 class="text-center mb-xxl">Похожие книги на английском</h2>
        <p class="text-center max-w-prose mx-auto mb-xl">
          Если вам нравится «{book.title}», попробуйте также эти книги уровня {level} в жанре {genreNames.split(',')[0].trim().toLowerCase()}.
        </p>
        <div class="related-grid">
          {relatedBooks.map(rb => (
            <a href={`/books/${toSlug(rb.title)}/`} class="related-book">
              <img class="related-book__cover" src={rb.imageUrl} alt={rb.title} loading="lazy" />
              <div class="related-book__info">
                <span class="related-book__level">{complexityToLevel[rb.complexity]}</span>
                <div class="related-book__title">{rb.title}</div>
                <div class="related-book__author">{rb.author}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section" style="padding-bottom: 0;">
    <div class="container text-center">
      <h2 class="mb-m">Читайте «{book.title}» на английском — бесплатно 7 дней</h2>
      <p class="max-w-prose mx-auto mb-l">
        Скачайте Readling, найдите «{book.title}» в каталоге и начните читать с переводом прямо сейчас.
      </p>
      <div class="store-buttons" style="justify-content: center;">
        <a href={links.appStore} target="_blank" rel="noopener" class="store-btn"><img src="/badge-appstore.svg" alt="Загрузите в App Store" /></a>
        <a href={links.googlePlay} target="_blank" rel="noopener" class="store-btn store-btn--google"><img src="/badge-google-play.png" alt="Доступно в Google Play" /></a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Вопросы о чтении «{book.title}» на английском</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Можно ли читать «{book.title}» ({book.author}) бесплатно?</summary>
          <div class="faq-item__answer">
            Да, Readling предоставляет 7 дней бесплатного доступа ко всем книгам и функциям, включая «{book.title}». Скачайте приложение и начните читать.
          </div>
        </details>
        <details class="faq-item">
          <summary>Какой уровень английского нужен для «{book.title}»?</summary>
          <div class="faq-item__answer">
            «{book.title}» рассчитана на уровень {level} ({levelDescription}). {isParallel ? `В режиме параллельного чтения вы видите русский перевод рядом с каждым предложением — это помогает даже при уровне ниже ${level}.` : `В режиме погружения текст начинается почти полностью на русском и постепенно переходит на английский — поэтому книга комфортна даже при уровне ниже ${level}.`} {book.complexity <= 2 ? 'Это одна из самых простых книг в каталоге — отлично подойдёт для первого чтения на английском.' : book.complexity >= 5 ? 'Это книга для продвинутых читателей — сложная лексика и авторский стиль.' : ''}
          </div>
        </details>
        <details class="faq-item">
          <summary>Как читать «{book.title}» в {isParallel ? 'параллельном режиме' : 'режиме погружения'}?</summary>
          <div class="faq-item__answer">
            {isParallel
              ? `Откройте «${book.title}» в Readling — вы увидите английский оригинал и русский перевод рядом, предложение за предложением. Нажмите на любое слово для мгновенного перевода и добавления в словарь.`
              : `Откройте «${book.title}» в Readling — текст начнётся почти на русском. С каждой страницей английских слов будет больше. К концу книги вы будете читать преимущественно на английском.`}
          </div>
        </details>
        <details class="faq-item">
          <summary>Какой жанр у книги «{book.title}»?</summary>
          <div class="faq-item__answer">
            «{book.title}» ({book.author}) относится к жанрам: {genreNames}. В каталоге Readling есть и другие книги этих жанров — выбирайте по уровню и интересам.
          </div>
        </details>
        <details class="faq-item">
          <summary>На каких устройствах можно читать «{book.title}»?</summary>
          <div class="faq-item__answer">
            Readling доступен на iPhone и Android-смартфонах. Скачайте бесплатно из App Store или Google Play и найдите «{book.title}» в каталоге.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Schema.org -->
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Book",
      "name": book.title,
      "author": { "@type": "Person", "name": book.author },
      "description": book.description,
      "image": book.imageUrl,
      "genre": genres.map((g: string) => genreLabels[g] || g),
      "inLanguage": "en",
      "audience": {
        "@type": "EducationalAudience",
        "educationalRole": "student",
        "suggestedMinAge": book.complexity <= 2 ? 10 : 14,
      },
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `Можно ли читать «${book.title}» (${book.author}) бесплатно?`,
          "acceptedAnswer": { "@type": "Answer", "text": `Да, Readling предоставляет 7 дней бесплатного доступа ко всем книгам, включая «${book.title}».` }
        },
        {
          "@type": "Question",
          "name": `Какой уровень английского нужен для «${book.title}»?`,
          "acceptedAnswer": { "@type": "Answer", "text": `«${book.title}» рассчитана на уровень ${level} (${levelDescription}).` }
        },
        {
          "@type": "Question",
          "name": `Какой жанр у книги «${book.title}»?`,
          "acceptedAnswer": { "@type": "Answer", "text": `«${book.title}» (${book.author}) относится к жанрам: ${genreNames}.` }
        },
        {
          "@type": "Question",
          "name": `На каких устройствах можно читать «${book.title}»?`,
          "acceptedAnswer": { "@type": "Answer", "text": "Readling доступен на iPhone и Android-смартфонах. Скачайте бесплатно из App Store или Google Play." }
        },
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://app.readling.club/" },
        { "@type": "ListItem", "position": 2, "name": "Книги", "item": "https://app.readling.club/books" },
        { "@type": "ListItem", "position": 3, "name": book.title, "item": `https://app.readling.club/books/${slug}` },
      ]
    })} />
  </Fragment>
</BaseLayout>

<style>
  .breadcrumbs {
    padding: var(--space-m) 0;
    font-size: 0.875rem;
    color: var(--color-text-tertiary);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-card-border);
  }

  .breadcrumbs a {
    color: var(--color-text-tertiary);
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs__sep {
    margin: 0 var(--space-xs);
  }

  .book-hero {
    background: var(--gradient-hero);
    padding: var(--space-3xl) 0 var(--space-4xl);
  }

  .book-hero__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .book-hero__cover img {
    width: 280px;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .book-hero__author {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .book-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }

  .tag {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    border: 1px solid var(--color-card-border);
    color: var(--color-text-secondary);
  }

  .tag--level {
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
    font-weight: 700;
  }

  .tag--mode {
    background: var(--color-primary-tint);
    color: var(--color-primary);
    border-color: rgba(0, 122, 255, 0.2);
    font-weight: 600;
  }

  .book-hero__desc {
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .book-details {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
  }

  .book-detail {
    background: var(--color-surface);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-md);
    padding: var(--space-l);
  }

  .book-detail__label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-xs);
  }

  .book-detail__value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-l);
  }

  .related-book {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .related-book:hover {
    transform: translateY(-4px);
    color: inherit;
  }

  .related-book__cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-card-border);
    background: var(--color-surface-alt);
    margin-bottom: var(--space-s);
  }

  .related-book__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .related-book__level {
    display: inline-block;
    width: fit-content;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-xs);
  }

  .related-book__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .related-book__author {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

