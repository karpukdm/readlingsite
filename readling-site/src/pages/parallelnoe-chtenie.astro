---
import BaseLayout from '../layouts/BaseLayout.astro';
import { links } from '../config/links';
import allBooks from '../data/books.json';

const books = allBooks.filter(b => !b.title.includes('Guide') && !b.title.includes('Руководство'));
const shuffled = [...books].sort(() => Math.random() - 0.5);
const featuredBooks = shuffled.slice(0, 8);
---

<BaseLayout
  title="Параллельное чтение на английском и русском — книги с переводом в Readling"
  description="Читайте книги на английском с русским переводом рядом. Параллельное чтение в Readling: оригинал и перевод предложение за предложением. Бесплатно 7 дней."
  canonicalPath="/parallelnoe-chtenie"
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <h1 class="mb-m">Параллельное чтение: книги на английском с русским переводом рядом</h1>
        <p class="hero__subtitle mb-l">
          Английский оригинал и русский перевод — предложение за предложением.
          Читайте, сравнивайте, учите грамматику и новые слова в контексте настоящих книг.
        </p>
        <div class="store-buttons">
          <a href={links.appStore} target="_blank" rel="noopener" class="store-btn"><img src="/badge-appstore.svg" alt="Загрузите в App Store" /></a>
          <a href={links.googlePlay} target="_blank" rel="noopener" class="store-btn store-btn--google"><img src="/badge-google-play.png" alt="Доступно в Google Play" /></a>
        </div>
      </div>
      <div class="hero__visual">
        <div class="screenshot-placeholder screenshot-placeholder--phone">
          Скриншот<br/>параллельного чтения
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IS -->
  <section class="section">
    <div class="container">
      <div class="what-section">
        <div class="what-section__text">
          <h2 class="mb-m">Что такое параллельное чтение и как оно помогает учить английский</h2>
          <p class="mb-m">
            Параллельное чтение — это способ читать книги на двух языках одновременно. Вы видите английский оригинал
            и русский перевод рядом — предложение напротив предложения. Если что-то непонятно в английском тексте,
            взгляд скользит на русский — и всё ясно.
          </p>
          <p class="mb-m">
            Не нужно переключаться между приложениями, листать словарь или гадать, правильно ли вы поняли.
            Параллельный перевод всегда рядом — как опытный преподаватель, который подсказывает, но не мешает.
          </p>
          <p>
            Это один из самых проверенных методов изучения языка через чтение.
            В Readling он доступен для всех книг каталога — более 200 книг в 25 жанрах.
          </p>
        </div>
        <div class="what-section__visual">
          <div class="screenshot-placeholder" style="min-height: 400px;">
            Скриншот<br/>параллельного чтения<br/>(крупный)
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO IS IT FOR -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center mb-xxl">Для кого параллельное чтение на английском</h2>
      <div class="grid-3">
        <div class="card">
          <div class="badge mb-m">B1–B2</div>
          <h3 class="mb-s">Средний уровень — расширяете словарный запас</h3>
          <p>
            Вы уже знаете базовую грамматику и самые частые слова. Параллельное чтение поможет выйти на следующий уровень:
            видеть новые конструкции, привыкать к длинным предложениям, понимать авторский стиль.
          </p>
        </div>
        <div class="card">
          <h3 class="mb-s">Изучаете грамматику — сравниваете структуру языков</h3>
          <p>
            Как англичане строят предложения? Где ставят подлежащее? Чем отличается порядок слов?
            Параллельный текст — идеальный способ увидеть грамматику в действии, а не в таблице из учебника.
          </p>
        </div>
        <div class="card">
          <h3 class="mb-s">Любите точность — хотите понять каждое слово</h3>
          <p>
            Режим погружения — про интуицию. Параллельное чтение — про понимание.
            Если вам важно разобраться в каждом предложении, этот режим для вас.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT LOOKS -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-xxl">Как выглядит параллельное чтение в приложении Readling</h2>
      <p class="text-center max-w-prose mx-auto mb-xxl">
        В Readling параллельное чтение — это не просто два столбца текста. Это интерактивный режим
        с переводом по нажатию, настройками шрифта и удобной навигацией.
      </p>

      <!-- Parallel demo -->
      <div class="parallel-demo max-w-wide mx-auto">
        <div class="parallel-demo__row">
          <div class="parallel-demo__en">
            <div class="parallel-demo__lang">English</div>
            <p>Anna opened the door and walked into the room. On the table lay a letter. She looked at the envelope and smiled.</p>
          </div>
          <div class="parallel-demo__ru">
            <div class="parallel-demo__lang">Русский</div>
            <p>Анна открыла дверь и вошла в комнату. На столе лежало письмо. Она посмотрела на конверт и улыбнулась.</p>
          </div>
        </div>
      </div>

      <div class="grid-3" style="margin-top: var(--space-xxl);">
        <div class="card text-center">
          <h3 class="mb-s">Параграф за параграфом</h3>
          <p>Английский и русский текст идут параграфами друг за другом. Удобно сравнивать.</p>
        </div>
        <div class="card text-center">
          <h3 class="mb-s">Перевод по нажатию</h3>
          <p>Нажмите на слово — увидите перевод и транскрипцию. Слово сохранится в словарь.</p>
        </div>
        <div class="card text-center">
          <h3 class="mb-s">Настройки под себя</h3>
          <p>Размер шрифта, интервал, тема оформления — светлая, тёмная, сепия.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="section section--alt">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Какой режим чтения выбрать — параллельный или погружение</h2>
      <p class="text-center max-w-prose mx-auto mb-xl">
        В Readling два режима чтения — погружение и параллельный. У каждой книги в каталоге указан доступный режим.
      </p>
      <table class="comparison-table">
        <thead>
          <tr>
            <th></th>
            <th>Параллельное чтение</th>
            <th>Режим погружения</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Что вы видите</strong></td>
            <td>Оригинал + перевод рядом</td>
            <td>Английский вплетён в русский текст</td>
          </tr>
          <tr>
            <td><strong>Лучше для</strong></td>
            <td>Грамматика, точное понимание</td>
            <td>Беглость, привыкание к языку</td>
          </tr>
          <tr>
            <td><strong>Подход</strong></td>
            <td>Аналитический — сравниваете</td>
            <td>Интуитивный — впитываете</td>
          </tr>
          <tr>
            <td><strong>Уровень</strong></td>
            <td>B1 и выше</td>
            <td>Любой, от A1</td>
          </tr>
        </tbody>
      </table>
      <p class="text-center" style="margin-top: var(--space-l);">
        <strong>Совет:</strong> начните с режима погружения, чтобы привыкнуть к английскому.
        Переключайтесь на параллельный, когда хотите разобрать сложный отрывок.
      </p>
      <div class="text-center" style="margin-top: var(--space-l);">
        <a href="/metod-pogruzheniya" class="btn btn--secondary">Подробнее о методе погружения &rarr;</a>
      </div>
    </div>
  </section>

  <!-- BOOKS -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-m">Книги с параллельным переводом — от A1 до C2</h2>
      <p class="text-center max-w-prose mx-auto mb-xl">
        В каталоге Readling — более 200 книг с параллельным переводом на русский. Детективы, фантастика, классика,
        романтика и другие жанры. Каждая книга доступна и в параллельном режиме, и в режиме погружения.
      </p>
      <div class="book-scroll">
        {featuredBooks.map(book => (
          <div class="book-card">
            <img class="book-card__cover" src={book.imageUrl} alt={book.title} loading="lazy" />
            <div class="book-card__title">{book.title}</div>
            <div class="book-card__author">{book.author}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="section section--alt">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Отзыв о параллельном чтении в Readling</h2>
      <div class="testimonial" style="max-width: 600px; margin: 0 auto;">
        <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="testimonial__text">
          &laquo;Наконец-то нашёл приложение, где параллельный перевод сделан удобно.
          Не PDF с двумя колонками, а нормальный интерактивный текст с переводом слов. Читаю каждый день.&raquo;
        </p>
        <p class="testimonial__author">Дмитрий — Google Play</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-bottom: 0;">
    <div class="container text-center">
      <h2 class="mb-m">Попробуйте параллельное чтение бесплатно</h2>
      <p class="max-w-prose mx-auto mb-l">
        Выберите книгу, откройте параллельный режим и начните читать на английском с переводом. 7 дней бесплатно.
      </p>
      <div class="store-buttons" style="justify-content: center;">
        <a href={links.appStore} target="_blank" rel="noopener" class="store-btn"><img src="/badge-appstore.svg" alt="Загрузите в App Store" /></a>
        <a href={links.googlePlay} target="_blank" rel="noopener" class="store-btn store-btn--google"><img src="/badge-google-play.png" alt="Доступно в Google Play" /></a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container max-w-wide mx-auto">
      <h2 class="text-center mb-xxl">Вопросы о параллельном чтении</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Чем параллельное чтение в Readling отличается от обычных книг с параллельным переводом?</summary>
          <div class="faq-item__answer">
            В Readling текст интерактивный: вы можете нажать на любое слово и увидеть перевод.
            Незнакомые слова сохраняются в личный словарь. А ещё можно в любой момент переключиться на режим погружения.
          </div>
        </details>
        <details class="faq-item">
          <summary>Для какого уровня подходит параллельное чтение?</summary>
          <div class="faq-item__answer">
            Лучше всего для B1 и выше — когда базовая грамматика уже знакома.
            Для начинающих (A1–A2) рекомендуем начать с режима погружения, где английский появляется постепенно.
          </div>
        </details>
        <details class="faq-item">
          <summary>Можно ли переключаться между параллельным чтением и режимом погружения?</summary>
          <div class="faq-item__answer">
            У каждой книги в каталоге указан доступный режим — погружение или параллельный. Выбирайте книгу с нужным вам режимом.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Schema.org -->
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Чем параллельное чтение в Readling отличается от обычных книг с параллельным переводом?",
          "acceptedAnswer": { "@type": "Answer", "text": "В Readling текст интерактивный: можно нажать на любое слово и увидеть перевод. Незнакомые слова сохраняются в личный словарь." }
        },
        {
          "@type": "Question",
          "name": "Для какого уровня подходит параллельное чтение?",
          "acceptedAnswer": { "@type": "Answer", "text": "Лучше всего для B1 и выше. Для начинающих рекомендуем режим погружения." }
        },
        {
          "@type": "Question",
          "name": "Можно ли переключаться между параллельным чтением и режимом погружения?",
          "acceptedAnswer": { "@type": "Answer", "text": "У каждой книги в каталоге указан доступный режим — погружение или параллельный." }
        }
      ]
    })} />
  </Fragment>
</BaseLayout>

<style>
  .hero {
    background: var(--color-surface);
    padding: var(--space-4xl) 0;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
  }

  .what-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  /* Parallel demo */
  .parallel-demo {
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .parallel-demo__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .parallel-demo__en,
  .parallel-demo__ru {
    padding: var(--space-l);
  }

  .parallel-demo__en {
    background: var(--color-primary-tint);
    border-right: 1px solid var(--color-card-border);
  }

  .parallel-demo__ru {
    background: var(--color-surface);
  }

  .parallel-demo__lang {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: var(--space-s);
  }

  .parallel-demo__en p,
  .parallel-demo__ru p {
    font-size: 1rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__visual {
      order: -1;
    }

    .store-buttons {
      justify-content: center;
    }

    .what-section {
      grid-template-columns: 1fr;
    }

    .parallel-demo__row {
      grid-template-columns: 1fr;
    }

    .parallel-demo__en {
      border-right: none;
      border-bottom: 1px solid var(--color-card-border);
    }
  }
</style>
